.container {
  padding: 40rpx;
  background-color: #fff;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.date {
  font-size: 32rpx;
  color: #333;
}

.photo-section {
  width: 100%;
  height: 400rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  overflow: hidden;
}

.camera-icon {
  font-size: 80rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.visibility-section {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.label {
  font-size: 28rpx;
  color: #999;
  margin-right: 40rpx;
}

.radio-group {
  display: flex;
}

.radio-item {
  margin-right: 30rpx;
  font-size: 28rpx;
  color: #333;
}

.content-section {
  margin-bottom: 100rpx;
}

.note-textarea {
  width: 100%;
  height: 300rpx;
  font-size: 30rpx;
  color: #333;
}

.footer {
  position: fixed;
  bottom: 60rpx;
  left: 40rpx;
  right: 40rpx;
}

.done-btn {
  background: linear-gradient(to right, #FFD700, #FFC107);
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
}
