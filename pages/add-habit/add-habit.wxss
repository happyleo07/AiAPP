.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.icon-swiper {
  height: 450rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 20rpx;
}

.icon-item {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.icon-item.active {
  background-color: #eee;
  transform: scale(1.1);
}

.white-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
}

.input-group {
  margin-bottom: 40rpx;
}

.input-group:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #ccc;
  margin-bottom: 20rpx;
}

.name-input {
  font-size: 32rpx;
  color: #333;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
}

.weekday-selector {
  display: flex;
  justify-content: space-between;
}

.day-item {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 26rpx;
  color: #999;
}

.day-item.active {
  background-color: #FFD700;
  color: #fff;
}

.footer {
  margin-top: 60rpx;
  padding-bottom: 60rpx;
}

.save-btn {
  background: linear-gradient(to right, #FFD700, #FFC107);
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
}
