.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.section {
  margin-bottom: 40rpx;
}

.label {
  font-size: 26rpx;
  color: #ccc;
  margin-bottom: 20rpx;
}

.user-selector {
  display: flex;
}

.user-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  border: 4rpx solid transparent;
}

.user-item.active {
  border-color: #FFD700;
}

.user-item .avatar {
  width: 100%;
  height: 100%;
}

.habit-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 10rpx 0;
}

.habit-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.habit-item:last-child {
  border-bottom: none;
}

.habit-item.active {
  background-color: #fcf8e3;
}

.habit-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.habit-name {
  font-size: 28rpx;
  color: #333;
}

.white-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
}

.input-group {
  margin-bottom: 40rpx;
}

.name-input {
  font-size: 30rpx;
  color: #333;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
}

.count-selector {
  text-align: center;
  padding: 20rpx 0;
}

.count-num {
  font-size: 60rpx;
  color: #FFD700;
  font-weight: bold;
}

.count-unit {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
}

.count-slider {
  margin-top: 20rpx;
}

.footer {
  margin-top: 60rpx;
  padding-bottom: 60rpx;
}

.save-btn {
  background: linear-gradient(to right, #FFD700, #FFC107);
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
}
