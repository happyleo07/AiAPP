<view class="discover-container">
  <!-- 顶部空余或展示语 -->
  <view class="header">
    <text class="slogan">你是我的习惯</text>
  </view>

  <!-- 中间核心功能图标 -->
  <view class="feature-grid">
    <view class="feature-item" bindtap="navToAddHabit">
      <view class="icon-box habit">
        <text class="iconfont">💛</text>
      </view>
      <text class="feature-name">习惯</text>
    </view>
    <view class="feature-item" bindtap="navToAddNote">
      <view class="icon-box note">
        <text class="iconfont">✍️</text>
      </view>
      <text class="feature-name">随笔</text>
    </view>
    <view class="feature-item" bindtap="navToAddReward">
      <view class="icon-box reward">
        <text class="iconfont">🎁</text>
      </view>
      <text class="feature-name">奖励</text>
    </view>
  </view>

  <!-- 底部辅助功能栏 (调整为均匀分布) -->
  <view class="sub-nav">
    <view class="sub-nav-item {{activeTab === 'square' ? 'active' : ''}}" bindtap="switchTab" data-tab="square">广场</view>
    <view class="add-center">
      <view class="circle-btn" bindtap="navToAddHabit">+</view>
    </view>
    <view class="sub-nav-item {{activeTab === 'reward' ? 'active' : ''}}" bindtap="switchTab" data-tab="reward">奖励</view>
  </view>

  <!-- 广场内容展示区 -->
  <view class="square-content" wx:if="{{activeTab === 'square'}}">
    <scroll-view class="square-scroll" scroll-y="true" bindscrolltolower="loadMoreNotes">
      <view class="note-card" wx:for="{{notes}}" wx:key="_id">
        <view class="note-header">
          <view class="note-date-box">
            <text class="calendar-icon">📅</text>
            <text class="note-date">{{item.date}}</text>
          </view>
          <view class="note-actions" wx:if="{{item._openid === openid}}">
            <text class="action-btn edit" bindtap="editNote" data-id="{{item._id}}" data-content="{{item.content}}">编辑</text>
            <text class="action-btn delete" bindtap="deleteNote" data-id="{{item._id}}" data-fileid="{{item.fileId}}">删除</text>
          </view>
        </view>
        <image class="note-image" wx:if="{{item.fileId}}" src="{{item.fileId}}" mode="aspectFill" bindtap="previewImage" bindlongpress="downloadImage" data-url="{{item.fileId}}"></image>
        <view class="note-body">
          <text class="note-text">{{item.content}}</text>
        </view>
      </view>

      <!-- 加载状态 -->
      <view class="load-status">
        <text wx:if="{{loading}}">正在加载中...</text>
        <text wx:elif="{{!hasMore && notes.length > 0}}">已经到底啦 ~</text>
        <text wx:elif="{{notes.length === 0 && !loading}}">广场上空空如也...</text>
      </view>
    </scroll-view>
  </view>
</view>
