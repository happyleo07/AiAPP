.profile-container {
  background-color: #f7f7f7;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 用户信息区域 */
.user-info-section {
  background-color: #fff;
  padding: 100rpx 40rpx 60rpx;
  display: flex;
  align-items: center;
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 12rpx;
  margin: 0 30rpx 0 0 !important;
  background: none;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname-input {
  font-size: 40rpx;
  font-weight: 600;
  color: #000;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.user-id {
  font-size: 28rpx;
  color: #7f7f7f;
}

.qr-code {
  color: #7f7f7f;
  font-size: 32rpx;
}

/* 菜单列表区域 */
.menu-list {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-item-left .iconfont {
  font-size: 32rpx;
  color: #000;
}

.menu-item-right {
  color: #b2b2b2;
  font-size: 32rpx;
}

/* 退出登录 */
.logout-section {
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.logout-btn {
  background-color: #fff;
  color: #fa5151;
  font-weight: normal;
  font-size: 32rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}

